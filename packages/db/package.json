{
  "name": "@aethon/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:sync": "tsx src/sync/sync-content.ts",
    "postinstall": "prisma generate",
    "db:studio": "prisma studio",
    "check-types": "tsc -b"
  },
  "dependencies": {
    "@aethon/env": "workspace:*",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "catalog:",
    "dotenv": "catalog:",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aethon/config": "workspace:*",
    "@aethon/content-core": "workspace:*",
    "@types/pg": "^8.16.0",
    "prisma": "^7.7.0",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}