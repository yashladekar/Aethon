{
  "extends": "@aethon/config/tsconfig.nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@aethon/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@aethon/roadmap-engine": [
        "../../packages/roadmap-engine/src/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "./node_modules"
  ]
}